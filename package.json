{
  "name": "root",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm lint:check && pnpm format:check && pnpm typecheck",
    "demo": "pnpm run --filter=nextjs-demo dev",
    "dev": "concurrently \"npm:lib:build:watch\" \"npm:demo\" -c auto,cyan",
    "fix": "pnpm lint && pnpm format",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lib:build": "pnpm run --filter=@marsidev/react-turnstile build",
    "lib:build:watch": "pnpm run --filter=@marsidev/react-turnstile build:watch",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "prepare": "simple-git-hooks",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm lib:build && cp LICENSE README.md packages/lib/ && changeset publish",
    "test": "pnpm run test:integration && pnpm run test:e2e",
    "test:e2e": "playwright test",
    "test:integration": "pnpm run --filter=@marsidev/react-turnstile test:integration",
    "typecheck": "pnpm run --parallel typecheck"
  },
  "devDependencies": {
    "@antfu/utils": "9.3.0",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@playwright/test": "1.61.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "concurrently": "10.0.3",
    "nano-staged": "1.0.2",
    "oxfmt": "0.56.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.23.0",
    "playwright": "1.61.1",
    "simple-git-hooks": "2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec nano-staged"
  },
  "nano-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,jsonc}": "oxfmt"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.8"
}
